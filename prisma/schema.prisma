  quotation    SalesQuotation?      @relation(fields: [id_quotation], references: [id_quotation])
  dokumen      ProjectDokumenLegal? @relation(fields: [id_dokumen_legal], references: [id_dokumen])
  jurnal_ar    IntegrationJurnalAr[]

  @@map("kontrak_layanan")
}

// ============================================================
// LAYER 6 — GUDANG OPERATIONS
// ============================================================

model GudangMutasiAset {
  id_mutasi      Int      @id @default(autoincrement())
  id_aset        Int
  jenis_mutasi   String   @db.VarChar(30)
  jumlah         Int      @default(1)
  id_project     Int?
  id_wo          Int?
  id_site_asal   Int?
  id_site_tujuan Int?
  keterangan     String?  @db.Text
  id_user        Int?
  created_at     DateTime @default(now())

  aset    GudangAset       @relation(fields: [id_aset], references: [id_aset], onDelete: Cascade)
  project ProjectDelivery? @relation(fields: [id_project], references: [id_project])
  wo      WorkOrder?       @relation(fields: [id_wo], references: [id_wo])
  user    CoreUser?        @relation(fields: [id_user], references: [id_user])

  @@map("gudang_mutasi_aset")
}

model SimTopup {
  id_topup    Int      @id @default(autoincrement())
  id_aset_sim Int
  id_site     Int
  jenis_topup String   @db.VarChar(30)
  nominal     Decimal  @db.Decimal(12, 2)
  tgl_topup   DateTime
  id_user     Int?
  keterangan  String?  @db.VarChar(255)
  created_at  DateTime @default(now())

  aset_sim GudangAset    @relation(fields: [id_aset_sim], references: [id_aset])
  site     SitePelanggan @relation(fields: [id_site], references: [id_site])
  user     CoreUser?     @relation(fields: [id_user], references: [id_user])

  @@map("sim_topup")
}

// ============================================================
// LAYER 7 — OPERATION HELPDESK (lanjutan)
// ============================================================

model OperationTicketLog {
  id_log      Int      @id @default(autoincrement())
  id_ticket   Int
  id_user     Int?
  status_dari String?  @db.VarChar(50)
  status_ke   String?  @db.VarChar(50)
  catatan     String?  @db.Text
  created_at  DateTime @default(now())

  ticket OperationTicket @relation(fields: [id_ticket], references: [id_ticket], onDelete: Cascade)
  user   CoreUser?       @relation(fields: [id_user], references: [id_user])

  @@map("operation_ticket_logs")
}

model OperationRca {
  id_rca           Int       @id @default(autoincrement())
  id_ticket        Int       @unique
  id_user_pembuat  Int?
  penyebab_utama   String?   @db.Text
  dampak           String?   @db.Text
  solusi_sementara String?   @db.Text
  solusi_permanen  String?   @db.Text
  tgl_rca          DateTime? @db.Date
  created_at       DateTime  @default(now())

  ticket OperationTicket @relation(fields: [id_ticket], references: [id_ticket], onDelete: Cascade)
  user   CoreUser?       @relation(fields: [id_user_pembuat], references: [id_user])

  @@map("operation_rca")
}

// ============================================================
// LAYER 8 — INTEGRASI EKSTERNAL
// ============================================================

model IntegrationJurnalAp {
  id_ap                    Int       @id @default(autoincrement())
  id_vendor                Int
  periode_tagihan          String    @db.VarChar(7)
  jumlah_tagihan           Decimal   @db.Decimal(15, 2)
  status_approval_internal String    @default("Pending") @db.VarChar(20)
  mekari_jurnal_uid        String?   @db.VarChar(100)
  status_sinkronisasi      String    @default("Belum") @db.VarChar(10)
  tanggal_sinkronisasi     DateTime?
  catatan                  String?   @db.Text
  created_at               DateTime  @default(now())

  vendor MasterVendorIsp @relation(fields: [id_vendor], references: [id_vendor])

  @@map("integration_jurnal_ap")
}

model IntegrationJurnalAr {
  id_ar                Int       @id @default(autoincrement())
  id_site              Int
  id_kontrak           Int?
  periode_tagihan      String    @db.VarChar(7)
  jumlah_tagihan       Decimal   @db.Decimal(15, 2)
  mekari_jurnal_uid    String?   @db.VarChar(100)
  status_sinkronisasi  String    @default("Belum") @db.VarChar(10)
  tanggal_sinkronisasi DateTime?
  catatan              String?   @db.Text
  created_at           DateTime  @default(now())

  site    SitePelanggan  @relation(fields: [id_site], references: [id_site])
  kontrak KontrakLayanan? @relation(fields: [id_kontrak], references: [id_kontrak])

  @@map("integration_jurnal_ar")
}

model IntegrationPrtgWebhook {
  id_webhook          Int      @id @default(autoincrement())
  prtg_sensor_id      String?  @db.VarChar(50)
  prtg_device_name    String?  @db.VarChar(150)
  prtg_sensor_name    String?  @db.VarChar(150)
  status_sensor       String?  @db.VarChar(50)
  pesan_alert         String?  @db.Text
  id_ticket_terbentuk Int?
  diterima_pada       DateTime @default(now())

  ticket OperationTicket? @relation(fields: [id_ticket_terbentuk], references: [id_ticket])

  @@map("integration_prtg_webhooks")
}

model IntegrationRcmsWebhook {
  id_webhook          Int      @id @default(autoincrement())
  rcms_device_id      String?  @db.VarChar(100)
  imei_device         String?  @db.VarChar(20)
  status_device       String?  @db.VarChar(20)
  network_type        String?  @db.VarChar(10)
  signal_strength     String?  @db.VarChar(20)
  sim1_status         String?  @db.VarChar(50)
  sim2_status         String?  @db.VarChar(50)
  pesan_raw           String?  @db.Text
  id_ticket_terbentuk Int?
  diterima_pada       DateTime @default(now())

  ticket OperationTicket? @relation(fields: [id_ticket_terbentuk], references: [id_ticket])

  @@map("integration_rcms_webhooks")
}

model IntegrationRuijieWebhook {
  id_webhook          Int      @id @default(autoincrement())
  ruijie_device_id    String?  @db.VarChar(100)
  device_mac          String?  @db.VarChar(20)
  device_type         String?  @db.VarChar(20)
  status_device       String?  @db.VarChar(20)
  jenis_alert         String?  @db.VarChar(100)
  pesan_raw           String?  @db.Text
  id_ticket_terbentuk Int?
  diterima_pada       DateTime @default(now())

  ticket OperationTicket? @relation(fields: [id_ticket_terbentuk], references: [id_ticket])

  @@map("integration_ruijie_webhooks")
}

// ============================================================
// LAYER 9 — ACTIVITY LOG
// ============================================================

model ActivityLog {
  id_log      Int      @id @default(autoincrement())
  id_user     Int?
  username    String   @db.VarChar(80)
  nama        String?  @db.VarChar(150)
  aksi        String   @db.VarChar(20)   // LOGIN, LOGOUT, CREATE, UPDATE, DELETE
  modul       String?  @db.VarChar(30)
  entitas     String?  @db.VarChar(60)
  deskripsi   String?  @db.Text
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now())

  @@index([id_user])
  @@index([created_at])
  @@map("activity_log")
}

// ERP NEXT1 — Prisma Schema
// Generated dari erp_NEXT1_FINAL_v4.sql (36 tabel)
// Database: MariaDB 11.8

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// LAYER 1 — MASTER REFERENCE
// ============================================================

model CoreRole {
  id_role    Int      @id @default(autoincrement())
  nama_role  String   @unique @db.VarChar(100)
  deskripsi  String?  @db.VarChar(255)
  created_at DateTime @default(now())

  user_roles CoreUserRole[]

  @@map("core_roles")
}

model HrisKaryawan {
  id_karyawan   Int       @id @default(autoincrement())
  nip           String    @unique @db.VarChar(20)
  nama_lengkap  String    @db.VarChar(150)
  jabatan       String    @db.VarChar(100)
  departemen    String    @db.VarChar(50)
  no_hp         String?   @db.VarChar(20)
  email         String?   @db.VarChar(150)
  tgl_bergabung DateTime? @db.Date
  status_aktif  Boolean   @default(true)
  created_at    DateTime  @default(now())

  tempat_lahir            String?   @db.VarChar(100)
  tgl_lahir               DateTime? @db.Date
  jenis_kelamin           String?   @db.VarChar(1)
  agama                   String?   @db.VarChar(30)
  status_pernikahan       String?   @db.VarChar(20)
  no_ktp                  String?   @unique @db.VarChar(20)
  alamat_ktp              String?   @db.Text
  no_npwp                 String?   @db.VarChar(30)
  pendidikan_terakhir     String?   @db.VarChar(30)
  kontak_darurat_nama     String?   @db.VarChar(150)
  kontak_darurat_hp       String?   @db.VarChar(20)
  kontak_darurat_hubungan String?   @db.VarChar(50)

  bank_nama        String? @db.VarChar(50)
  bank_no_rekening String? @db.VarChar(50)
  bank_atas_nama   String? @db.VarChar(150)

  foto_url String? @db.LongText

  user                CoreUser?
  leads_pic           SalesLead[]        @relation("SalesPic")
  opportunities       SalesOpportunity[] @relation("OppSalesPic")
  activities          SalesActivity[]    @relation("ActivitySalesPic")
  surveys             PresalesSurvey[]   @relation("SurveyPic")
  quotations          SalesQuotation[]   @relation("QuoSalesPic")
  quotations_approved SalesQuotation[]   @relation("QuoApprover")
  projects_pm         ProjectDelivery[]
  tickets_teknisi     OperationTicket[]
  wo_teknisi          WorkOrder[]        @relation("WoTeknisiInternal")
  invitation          HrisInvitation?

  @@map("hris_karyawan")
}

// Link undangan sign-in mandiri untuk karyawan baru — token dibuat oleh
// admin/HR (tanpa isi data), dibagikan manual (WA/dll) ke calon karyawan.
// Calon karyawan buka link publik, isi semua data sendiri; setelah submit
// akun otomatis dibuat dengan akses terbatas (modul_akses ['pending']) —
// admin tetap perlu review & buka akses modul yang sesuai via User Management.
model HrisInvitation {
  id_invitation Int       @id @default(autoincrement())
  token         String    @unique @db.VarChar(64)
  departemen    String?   @db.VarChar(50)
  jabatan       String?   @db.VarChar(100)
  status        String    @default("Pending") @db.VarChar(20)
  expires_at    DateTime
  used_at       DateTime?
  id_karyawan   Int?      @unique
  created_by    Int
  created_at    DateTime  @default(now())

  admin    CoreUser      @relation(fields: [created_by], references: [id_user])
  karyawan HrisKaryawan? @relation(fields: [id_karyawan], references: [id_karyawan])

  @@map("hris_invitations")
}

model Pelanggan {
  id_pelanggan        Int      @id @default(autoincrement())
  kode_pelanggan      String   @unique @db.VarChar(20)
  nama_pelanggan      String   @db.VarChar(200)
  npwp                String?  @db.VarChar(30)
  alamat_kantor       String?  @db.Text
  email_billing       String?  @db.VarChar(150)
  no_telp             String?  @db.VarChar(20)
  nama_pic_utama      String?  @db.VarChar(100)
  no_hp_pic_utama     String?  @db.VarChar(20)
  has_grup            Boolean  @default(false)
  nama_grup           String?  @db.VarChar(150)
  mekari_customer_uid String?  @db.VarChar(100)
  created_at          DateTime @default(now())

  sites SitePelanggan[]

  @@map("pelanggan")
}

model MasterLayanan {
  id_layanan         Int     @id @default(autoincrement())
  kode_layanan       String  @unique @db.VarChar(20)
  nama_layanan       String  @db.VarChar(100)
  deskripsi          String? @db.Text
  is_managed         Boolean @default(true)
  is_aktif           Boolean @default(true)
  mekari_product_uid String? @db.VarChar(100)

  sites         SitePelanggan[]
  opportunities SalesOpportunity[]
  kontrak       KontrakLayanan[]

  @@map("master_layanan")
}

model MasterVendorIsp {
  id_vendor        Int      @id @default(autoincrement())
  nama_vendor      String   @unique @db.VarChar(150)
  tipe_vendor      String   @db.VarChar(30)
  kontak_pic       String?  @db.VarChar(100)
  email_pic        String?  @db.VarChar(150)
  no_telp          String?  @db.VarChar(20)
  alamat           String?  @db.Text
  bank_nama        String?  @db.VarChar(50)
  bank_no_rekening String?  @db.VarChar(50)
  bank_atas_nama   String?  @db.VarChar(150)
  catatan          String?  @db.Text
  is_aktif         Boolean  @default(true)
  created_at       DateTime @default(now())

  sumber_internet    SumberInternetSite[]
  surveys_isp        PresalesSurvey[]
  work_orders_vendor WorkOrder[]           @relation("WoVendorKetiga")
  jurnal_ap          IntegrationJurnalAp[]

  @@map("master_vendor_isp")
}

// Master gudang fisik (Jakarta, Surabaya, dst)
model MasterGudang {
  id_gudang   Int      @id @default(autoincrement())
  kode_gudang String   @unique @db.VarChar(20)
  nama_gudang String   @db.VarChar(100)
  kota        String?  @db.VarChar(100)
  alamat      String?  @db.Text
  is_aktif    Boolean  @default(true)
  created_at  DateTime @default(now())

  aset      GudangAset[]
  opname    StokOpname[]
  pengajuan PengajuanAset[]

  @@map("master_gudang")
}

// Kontak orang pemasang / teknisi pihak ketiga (freelance/borongan)
model MasterKontakTeknisi {
  id_kontak        Int      @id @default(autoincrement())
  nama             String   @db.VarChar(150)
  no_hp            String   @db.VarChar(20) // HP / WA
  alamat           String?  @db.Text
  asal_vendor      String?  @db.VarChar(150) // perusahaan/tim asal (bebas)
  keahlian         String?  @db.VarChar(150) // mis. FO splicing, wireless, CCTV
  bank_nama        String?  @db.VarChar(50)
  bank_no_rekening String?  @db.VarChar(50)
  bank_atas_nama   String?  @db.VarChar(150)
  catatan          String?  @db.Text
  is_aktif         Boolean  @default(true)
  created_at       DateTime @default(now())

  @@map("master_kontak_teknisi")
}

// ============================================================
// LAYER 2 — USER & ACCESS
// ============================================================

model CoreUser {
  id_user       Int       @id @default(autoincrement())
  id_karyawan   Int       @unique
  username      String    @unique @db.VarChar(80)
  password_hash String    @db.VarChar(255)
  is_aktif      Boolean   @default(true)
  modul_akses   String?   @db.Text
  last_login    DateTime?
  created_at    DateTime  @default(now())

  karyawan            HrisKaryawan         @relation(fields: [id_karyawan], references: [id_karyawan])
  user_roles          CoreUserRole[]
  mutasi              GudangMutasiAset[]
  topup               SimTopup[]
  ticket_logs         OperationTicketLog[]
  rca                 OperationRca[]
  invoice_pembayaran  InvoicePembayaran[]
  stok_opname         StokOpname[]
  pengajuan_dibuat    PengajuanAset[]      @relation("PengajuanPemohon")
  pengajuan_disetujui PengajuanAset[]      @relation("PengajuanApprover")
  email_account       EmailAccount?
  invitations_dibuat  HrisInvitation[]

  @@map("core_users")
}

// Koneksi email IMAP/SMTP per user (self-service, mis. akun Hostinger
// webmail) — 1 user = 1 akun. Password disimpan terenkripsi (AES-256-GCM),
// bukan plaintext. Tidak ada sinkronisasi/cache pesan — semua ditarik
// live dari server IMAP tiap kali dibuka.
model EmailAccount {
  id_email_account Int      @id @default(autoincrement())
  id_user          Int      @unique
  email_address    String   @db.VarChar(150)
  imap_host        String   @db.VarChar(150)
  imap_port        Int      @default(993)
  smtp_host        String   @db.VarChar(150)
  smtp_port        Int      @default(465)
  password_enc     String   @db.Text
  is_aktif         Boolean  @default(true)
  last_error       String?  @db.Text
  connected_at     DateTime @default(now())

  user CoreUser @relation(fields: [id_user], references: [id_user], onDelete: Cascade)

  @@map("email_accounts")
}

model CoreUserRole {
  id         Int      @id @default(autoincrement())
  id_user    Int
  id_role    Int
  created_at DateTime @default(now())

  user CoreUser @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  role CoreRole @relation(fields: [id_role], references: [id_role], onDelete: Cascade)

  @@unique([id_user, id_role])
  @@map("core_user_roles")
}

// ============================================================
// LAYER 3 — SITE, ASET & PERANGKAT
// ============================================================

model SitePelanggan {
  id_site        Int       @id @default(autoincrement())
  id_pelanggan   Int
  id_layanan     Int
  kode_site      String    @unique @db.VarChar(50)
  nama_site      String    @db.VarChar(150)
  alamat_lengkap String    @db.Text
  kota           String?   @db.VarChar(100)
  provinsi       String?   @db.VarChar(100)
  koordinat_gps  String?   @db.VarChar(50)
  status_site    String    @default("Prospek") @db.VarChar(30)
  tgl_aktif      DateTime? @db.Date
  tgl_terminasi  DateTime? @db.Date
  catatan        String?   @db.Text
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  pelanggan       Pelanggan                @relation(fields: [id_pelanggan], references: [id_pelanggan])
  layanan         MasterLayanan            @relation(fields: [id_layanan], references: [id_layanan])
  aset            GudangAset[]
  perangkat       PerangkatSite[]
  pic             PicSite[]
  sumber_internet SumberInternetSite[]
  projects        ProjectDelivery[]
  tickets         OperationTicket[]
  work_orders     WorkOrder[]
  kontrak         KontrakLayanan[]
  topup           SimTopup[]
  jurnal_ar       IntegrationJurnalAr[]
  invoices        Invoice[]
  prtg_mapping    IntegrationPrtgMapping[]

  @@map("site_pelanggan")
}

model GudangAset {
  id_aset         Int       @id @default(autoincrement())
  kode_aset       String    @unique @db.VarChar(50)
  nama_perangkat  String    @db.VarChar(150)
  merk            String?   @db.VarChar(100)
  tipe_model      String?   @db.VarChar(100)
  serial_number   String?   @unique @db.VarChar(100)
  is_serialized   Boolean   @default(true)
  stok_jumlah     Int       @default(1)
  kategori        String    @db.VarChar(30)
  kondisi         String    @default("Baru") @db.VarChar(20)
  status_aset     String    @default("Di_Gudang") @db.VarChar(30)
  id_site         Int?
  id_gudang       Int?
  tgl_perolehan   DateTime? @db.Date
  harga_perolehan Decimal   @default(0) @db.Decimal(15, 2)
  catatan         String?   @db.Text
  created_at      DateTime  @default(now())

  site             SitePelanggan?      @relation(fields: [id_site], references: [id_site], onDelete: SetNull)
  gudang           MasterGudang?       @relation(fields: [id_gudang], references: [id_gudang], onDelete: SetNull)
  perangkat        PerangkatSite[]
  sumber_internet  SumberInternetSite?
  mutasi           GudangMutasiAset[]
  topup            SimTopup[]
  ba_material      WoBaMaterial[]
  pengiriman_items PengirimanItem[]
  opname_items     StokOpnameItem[]
  pengajuan_asal   PengajuanAset?

  @@map("gudang_aset")
}

model PerangkatSite {
  id_perangkat     Int       @id @default(autoincrement())
  id_site          Int
  id_aset          Int?
  jenis_perangkat  String    @db.VarChar(30)
  merk             String?   @db.VarChar(100)
  tipe_model       String?   @db.VarChar(100)
  serial_number    String?   @db.VarChar(100)
  ip_address       String?   @db.VarChar(45)
  mac_address      String?   @db.VarChar(20)
  ruijie_device_id String?   @db.VarChar(100)
  rcms_device_id   String?   @db.VarChar(100)
  tgl_pasang       DateTime? @db.Date
  status_perangkat String    @default("Aktif") @db.VarChar(20)
  catatan          String?   @db.Text
  created_at       DateTime  @default(now())

  site    SitePelanggan     @relation(fields: [id_site], references: [id_site], onDelete: Cascade)
  aset    GudangAset?       @relation(fields: [id_aset], references: [id_aset], onDelete: SetNull)
  tickets OperationTicket[]

  @@map("perangkat_site")
}

model PicSite {
  id_pic     Int      @id @default(autoincrement())
  id_site    Int
  nama_pic   String   @db.VarChar(150)
  jabatan    String?  @db.VarChar(100)
  no_kontak  String?  @db.VarChar(20)
  email      String?  @db.VarChar(150)
  is_utama   Boolean  @default(false)
  created_at DateTime @default(now())

  site SitePelanggan @relation(fields: [id_site], references: [id_site], onDelete: Cascade)

  @@map("pic_site")
}

model SumberInternetSite {
  id_sumber           Int       @id @default(autoincrement())
  id_site             Int
  id_vendor_isp       Int
  nomor_pelanggan_isp String?   @db.VarChar(100)
  peruntukan_link     String    @default("Main") @db.VarChar(20)
  bandwidth_mbps      String?   @db.VarChar(30)
  biaya_mrc_vendor    Decimal   @default(0) @db.Decimal(15, 2)
  id_aset_sim         Int?      @unique
  tgl_mulai           DateTime? @db.Date
  tgl_berakhir        DateTime? @db.Date
  status_link         String    @default("Aktif") @db.VarChar(20)
  catatan             String?   @db.Text
  created_at          DateTime  @default(now())

  site     SitePelanggan   @relation(fields: [id_site], references: [id_site], onDelete: Cascade)
  vendor   MasterVendorIsp @relation(fields: [id_vendor_isp], references: [id_vendor])
  aset_sim GudangAset?     @relation(fields: [id_aset_sim], references: [id_aset])
  topup    SimTopup[]

  @@map("sumber_internet_site")
}

// ============================================================
// LAYER 4 — SALES PIPELINE
// ============================================================

model SalesLead {
  id_lead         Int      @id @default(autoincrement())
  nama_prospek    String   @db.VarChar(200)
  nama_perusahaan String?  @db.VarChar(200)
  no_kontak       String?  @db.VarChar(20)
  email           String?  @db.VarChar(150)
  sumber_lead     String   @default("Lainnya") @db.VarChar(30)
  id_sales_pic    Int
  status_lead     String   @default("Baru") @db.VarChar(20)
  catatan_awal    String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  sales_pic     HrisKaryawan       @relation("SalesPic", fields: [id_sales_pic], references: [id_karyawan])
  opportunities SalesOpportunity[]
  activities    SalesActivity[]

  @@map("sales_leads")
}

model SalesOpportunity {
  id_opportunity   Int       @id @default(autoincrement())
  id_lead          Int
  id_layanan       Int?
  nama_opportunity String    @db.VarChar(200)
  id_sales_pic     Int
  estimasi_nilai   Decimal   @default(0) @db.Decimal(15, 2)
  tahapan          String    @default("Prospecting") @db.VarChar(30)
  alasan_lost      String?   @db.Text
  tgl_target_close DateTime? @db.Date
  catatan          String?   @db.Text
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  lead       SalesLead         @relation(fields: [id_lead], references: [id_lead])
  layanan    MasterLayanan?    @relation(fields: [id_layanan], references: [id_layanan])
  sales_pic  HrisKaryawan      @relation("OppSalesPic", fields: [id_sales_pic], references: [id_karyawan])
  activities SalesActivity[]
  surveys    PresalesSurvey[]
  quotations SalesQuotation[]
  projects   ProjectDelivery[]

  @@map("sales_opportunities")
}

model SalesActivity {
  id_activity       Int      @id @default(autoincrement())
  id_lead           Int?
  id_opportunity    Int?
  id_sales_pic      Int
  jenis_aktivitas   String   @db.VarChar(30)
  tanggal_aktivitas DateTime
  ringkasan         String   @db.Text
  hasil             String   @default("Netral") @db.VarChar(20)
  created_at        DateTime @default(now())

  lead        SalesLead?        @relation(fields: [id_lead], references: [id_lead])
  opportunity SalesOpportunity? @relation(fields: [id_opportunity], references: [id_opportunity])
  sales_pic   HrisKaryawan      @relation("ActivitySalesPic", fields: [id_sales_pic], references: [id_karyawan])

  @@map("sales_activities")
}

model PresalesSurvey {
  id_survey           Int      @id @default(autoincrement())
  id_opportunity      Int
  id_presales_pic     Int
  tanggal_survey      DateTime @db.Date
  alamat_survey       String   @db.Text
  koordinat_gps       String?  @db.VarChar(50)
  id_rekomendasi_isp  Int?
  rekomendasi_layanan String?  @db.VarChar(255)
  catatan_teknis      String?  @db.Text
  hasil_survey        String   @default("Feasible") @db.VarChar(30)
  file_foto_survey    String?  @db.VarChar(255)
  created_at          DateTime @default(now())

  opportunity     SalesOpportunity @relation(fields: [id_opportunity], references: [id_opportunity])
  presales_pic    HrisKaryawan     @relation("SurveyPic", fields: [id_presales_pic], references: [id_karyawan])
  rekomendasi_isp MasterVendorIsp? @relation(fields: [id_rekomendasi_isp], references: [id_vendor])

  @@map("presales_surveys")
}

model SalesQuotation {
  id_quotation       Int       @id @default(autoincrement())
  id_opportunity     Int
  nomor_quotation    String    @unique @db.VarChar(100)
  id_sales_pic       Int
  tgl_quotation      DateTime  @db.Date
  tgl_berlaku_sampai DateTime? @db.Date
  harga_mrc          Decimal   @default(0) @db.Decimal(15, 2)
  harga_otc          Decimal   @default(0) @db.Decimal(15, 2)
  status_approval    String    @default("Draft") @db.VarChar(20)
  id_approver        Int?
  tgl_approval       DateTime?
  catatan_approval   String?   @db.Text
  catatan            String?   @db.Text
  file_pdf           String?   @db.VarChar(255)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  opportunity SalesOpportunity @relation(fields: [id_opportunity], references: [id_opportunity])
  sales_pic   HrisKaryawan     @relation("QuoSalesPic", fields: [id_sales_pic], references: [id_karyawan])
  approver    HrisKaryawan?    @relation("QuoApprover", fields: [id_approver], references: [id_karyawan])
  kontrak     KontrakLayanan[]

  @@map("sales_quotations")
}

// ============================================================
// LAYER 5 — PROJECT & WORK ORDERS
// ============================================================

model ProjectDelivery {
  id_project         Int       @id @default(autoincrement())
  nomor_project      String    @unique @db.VarChar(100)
  id_opportunity     Int
  id_site            Int
  id_pm              Int
  id_kontrak         Int?
  tgl_mulai          DateTime? @db.Date
  tgl_target_selesai DateTime? @db.Date
  tgl_actual_selesai DateTime? @db.Date
  status_project     String    @default("Perencanaan") @db.VarChar(30)
  catatan            String?   @db.Text
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  opportunity SalesOpportunity      @relation(fields: [id_opportunity], references: [id_opportunity])
  site        SitePelanggan         @relation(fields: [id_site], references: [id_site])
  pm          HrisKaryawan          @relation(fields: [id_pm], references: [id_karyawan])
  kontrak     KontrakLayanan?       @relation(fields: [id_kontrak], references: [id_kontrak])
  work_orders WorkOrder[]
  mutasi      GudangMutasiAset[]
  bast        ProjectDokumenLegal[]

  @@map("project_delivery")
}

model OperationTicket {
  id_ticket                  Int       @id @default(autoincrement())
  nomor_tiket                String    @unique @db.VarChar(100)
  id_site                    Int
  id_perangkat               Int?
  id_teknisi_pic             Int?
  sumber_tiket               String    @default("Internal") @db.VarChar(30)
  socialchat_conversation_id String?   @db.VarChar(100)
  judul_tiket                String    @db.VarChar(255)
  deskripsi_masalah          String?   @db.Text
  prioritas                  String    @default("Medium") @db.VarChar(20)
  status_tiket               String    @default("Open") @db.VarChar(30)
  tgl_open                   DateTime  @default(now())
  tgl_resolved               DateTime?
  tgl_closed                 DateTime?
  sla_due                    DateTime?
  sla_breached               Boolean   @default(false)
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  site            SitePelanggan              @relation(fields: [id_site], references: [id_site])
  perangkat       PerangkatSite?             @relation(fields: [id_perangkat], references: [id_perangkat])
  teknisi         HrisKaryawan?              @relation(fields: [id_teknisi_pic], references: [id_karyawan])
  work_orders     WorkOrder[]
  logs            OperationTicketLog[]
  rca             OperationRca?
  prtg_webhooks   IntegrationPrtgWebhook[]
  rcms_webhooks   IntegrationRcmsWebhook[]
  ruijie_webhooks IntegrationRuijieWebhook[]

  @@index([status_tiket])
  @@index([status_tiket, tgl_open])
  @@map("operation_tickets")
}

model WorkOrder {
  id_wo                 Int       @id @default(autoincrement())
  nomor_wo              String    @unique @db.VarChar(100)
  jenis_wo              String    @db.VarChar(30)
  id_project            Int?
  id_ticket             Int?
  id_site               Int
  tipe_eksekutor        String    @default("Internal_NEXT1") @db.VarChar(30)
  id_teknisi_internal   Int?
  id_vendor_ketiga      Int?
  fee_vendor            Decimal   @default(0) @db.Decimal(15, 2)
  status_pembayaran_fee String    @default("Belum_Dibayar") @db.VarChar(20)
  tgl_jadwal            DateTime
  deskripsi_tugas       String    @db.Text
  status_wo             String    @default("Open") @db.VarChar(30)
  koordinat_checkin     String?   @db.VarChar(100)
  catatan_teknisi       String?   @db.Text
  created_at            DateTime  @default(now())
  completed_at          DateTime?

  project      ProjectDelivery?      @relation(fields: [id_project], references: [id_project])
  ticket       OperationTicket?      @relation(fields: [id_ticket], references: [id_ticket])
  site         SitePelanggan         @relation(fields: [id_site], references: [id_site])
  teknisi      HrisKaryawan?         @relation("WoTeknisiInternal", fields: [id_teknisi_internal], references: [id_karyawan])
  vendor       MasterVendorIsp?      @relation("WoVendorKetiga", fields: [id_vendor_ketiga], references: [id_vendor])
  foto         WoFoto[]
  berita_acara WoBeritaAcara[]
  pengiriman   PengirimanPerangkat[]
  mutasi       GudangMutasiAset[]

  @@map("work_orders")
}

model WoFoto {
  id_foto    Int      @id @default(autoincrement())
  id_wo      Int
  jenis_foto String   @default("Lainnya") @db.VarChar(30)
  file_path  String   @db.VarChar(255)
  catatan    String?  @db.VarChar(255)
  created_at DateTime @default(now())

  wo WorkOrder @relation(fields: [id_wo], references: [id_wo], onDelete: Cascade)

  @@map("wo_foto")
}

model WoBeritaAcara {
  id_ba                           Int       @id @default(autoincrement())
  id_wo                           Int
  nomor_ba                        String    @unique @db.VarChar(100)
  jenis_ba                        String    @db.VarChar(30)
  nama_penandatangan_next1        String?   @db.VarChar(150)
  nama_penandatangan_pelanggan    String?   @db.VarChar(150)
  jabatan_penandatangan_pelanggan String?   @db.VarChar(100)
  status_ba                       String    @default("Draft") @db.VarChar(20)
  tgl_ditandatangani              DateTime?
  file_ba_pdf                     String?   @db.VarChar(255)
  catatan                         String?   @db.Text
  created_at                      DateTime  @default(now())

  wo       WorkOrder      @relation(fields: [id_wo], references: [id_wo], onDelete: Cascade)
  material WoBaMaterial[]

  @@map("wo_berita_acara")
}

model WoBaMaterial {
  id_material   Int     @id @default(autoincrement())
  id_ba         Int
  id_aset       Int?
  nama_item     String  @db.VarChar(150)
  merk          String? @db.VarChar(100)
  tipe_model    String? @db.VarChar(100)
  serial_number String? @db.VarChar(100)
  jumlah        Int     @default(1)
  keterangan    String  @default("Penyerahan") @db.VarChar(30)

  ba   WoBeritaAcara @relation(fields: [id_ba], references: [id_ba], onDelete: Cascade)
  aset GudangAset?   @relation(fields: [id_aset], references: [id_aset])

  @@map("wo_ba_material")
}

model PengirimanPerangkat {
  id_pengiriman           Int       @id @default(autoincrement())
  id_wo                   Int
  jenis_pengiriman        String    @default("Dibawa_Teknisi") @db.VarChar(30)
  nama_ekspedisi          String?   @db.VarChar(100)
  nomor_resi              String?   @db.VarChar(100)
  status_pengiriman       String    @default("Packing") @db.VarChar(30)
  tgl_kirim               DateTime?
  tgl_terima              DateTime?
  nama_penerima_di_lokasi String?   @db.VarChar(150)
  catatan                 String?   @db.Text
  created_at              DateTime  @default(now())

  wo    WorkOrder        @relation(fields: [id_wo], references: [id_wo], onDelete: Cascade)
  items PengirimanItem[]

  @@map("pengiriman_perangkat")
}

model PengirimanItem {
  id_item       Int     @id @default(autoincrement())
  id_pengiriman Int
  id_aset       Int?
  nama_item     String  @db.VarChar(150)
  jumlah        Int     @default(1)
  keterangan    String? @db.VarChar(255)

  pengiriman PengirimanPerangkat @relation(fields: [id_pengiriman], references: [id_pengiriman], onDelete: Cascade)
  aset       GudangAset?         @relation(fields: [id_aset], references: [id_aset])

  @@map("pengiriman_items")
}

model ProjectDokumenLegal {
  id_dokumen                      Int       @id @default(autoincrement())
  id_project                      Int
  nomor_bast                      String    @unique @db.VarChar(100)
  nama_penandatangan_pelanggan    String?   @db.VarChar(150)
  jabatan_penandatangan_pelanggan String?   @db.VarChar(100)
  tgl_ditandatangani              DateTime? @db.Date
  file_bast_pdf                   String?   @db.VarChar(255)
  mekari_invoice_uid              String?   @db.VarChar(100)
  status_sinkronisasi_finance     String    @default("Belum") @db.VarChar(10)
  catatan                         String?   @db.Text
  created_at                      DateTime  @default(now())

  project ProjectDelivery  @relation(fields: [id_project], references: [id_project])
  kontrak KontrakLayanan[]

  @@map("project_dokumen_legal")
}

model KontrakLayanan {
  id_kontrak        Int       @id @default(autoincrement())
  id_site           Int
  id_layanan        Int
  id_quotation      Int?
  id_dokumen_legal  Int?
  nomor_kontrak     String    @unique @db.VarChar(100)
  tgl_mulai         DateTime  @db.Date
  tgl_berakhir      DateTime? @db.Date
  durasi_bulan      Int       @default(12)
  harga_mrc         Decimal   @db.Decimal(15, 2)
  harga_otc         Decimal   @default(0) @db.Decimal(15, 2)
  status_kontrak    String    @default("Aktif") @db.VarChar(20)
  tanggal_terminasi DateTime? @db.Date
  alasan_terminasi  String?   @db.Text
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  site      SitePelanggan         @relation(fields: [id_site], references: [id_site])
  layanan   MasterLayanan         @relation(fields: [id_layanan], references: [id_layanan])
  quotation SalesQuotation?       @relation(fields: [id_quotation], references: [id_quotation])
  dokumen   ProjectDokumenLegal?  @relation(fields: [id_dokumen_legal], references: [id_dokumen])
  jurnal_ar IntegrationJurnalAr[]
  projects  ProjectDelivery[]
  invoices  Invoice[]

  @@map("kontrak_layanan")
}

// ============================================================
// LAYER 6 — GUDANG OPERATIONS
// ============================================================

model GudangMutasiAset {
  id_mutasi        Int      @id @default(autoincrement())
  id_aset          Int
  jenis_mutasi     String   @db.VarChar(30)
  jumlah           Int      @default(1)
  id_project       Int?
  id_wo            Int?
  id_site_asal     Int?
  id_site_tujuan   Int?
  id_gudang_asal   Int?
  id_gudang_tujuan Int?
  keterangan       String?  @db.Text
  id_user          Int?
  created_at       DateTime @default(now())

  aset    GudangAset       @relation(fields: [id_aset], references: [id_aset], onDelete: Cascade)
  project ProjectDelivery? @relation(fields: [id_project], references: [id_project])
  wo      WorkOrder?       @relation(fields: [id_wo], references: [id_wo])
  user    CoreUser?        @relation(fields: [id_user], references: [id_user])

  @@map("gudang_mutasi_aset")
}

// Sesi stok opname / audit fisik per gudang — snapshot aset "Di_Gudang"
// saat sesi dibuat, lalu tim mencocokkan lewat scan/input kode_aset.
model StokOpname {
  id_opname     Int       @id @default(autoincrement())
  id_gudang     Int
  status_opname String    @default("Berjalan") @db.VarChar(20)
  catatan       String?   @db.Text
  id_user_buat  Int?
  tgl_mulai     DateTime  @default(now())
  tgl_selesai   DateTime?
  created_at    DateTime  @default(now())

  gudang    MasterGudang     @relation(fields: [id_gudang], references: [id_gudang])
  user_buat CoreUser?        @relation(fields: [id_user_buat], references: [id_user])
  items     StokOpnameItem[]

  @@map("stok_opname")
}

model StokOpnameItem {
  id_item         Int       @id @default(autoincrement())
  id_opname       Int
  id_aset         Int
  ditemukan       Boolean   @default(false)
  tidak_terdaftar Boolean   @default(false)
  waktu_scan      DateTime?
  catatan         String?   @db.Text
  created_at      DateTime  @default(now())

  opname StokOpname @relation(fields: [id_opname], references: [id_opname], onDelete: Cascade)
  aset   GudangAset @relation(fields: [id_aset], references: [id_aset])

  @@unique([id_opname, id_aset])
  @@map("stok_opname_item")
}

// Pengajuan pembelian aset baru — approval Director/Manager_Ops sebelum
// dibeli, lalu dikonversi jadi GudangAset setelah barang fisik tiba.
model PengajuanAset {
  id_pengajuan     Int       @id @default(autoincrement())
  nama_item        String    @db.VarChar(150)
  kategori         String    @db.VarChar(30)
  jumlah           Int       @default(1)
  alasan           String    @db.Text
  estimasi_harga   Decimal   @default(0) @db.Decimal(15, 2)
  id_gudang_tujuan Int?
  status_pengajuan String    @default("Diajukan") @db.VarChar(20)
  id_pemohon       Int
  id_approver      Int?
  catatan_approval String?   @db.Text
  id_aset_hasil    Int?      @unique
  tgl_diajukan     DateTime  @default(now())
  tgl_approval     DateTime?
  tgl_selesai      DateTime?
  created_at       DateTime  @default(now())

  gudang_tujuan MasterGudang? @relation(fields: [id_gudang_tujuan], references: [id_gudang])
  pemohon       CoreUser      @relation("PengajuanPemohon", fields: [id_pemohon], references: [id_user])
  approver      CoreUser?     @relation("PengajuanApprover", fields: [id_approver], references: [id_user])
  aset_hasil    GudangAset?   @relation(fields: [id_aset_hasil], references: [id_aset])

  @@map("pengajuan_aset")
}

model SimTopup {
  id_topup    Int      @id @default(autoincrement())
  id_sumber   Int?
  id_aset_sim Int?
  id_site     Int
  jenis_topup String   @db.VarChar(30)
  nominal     Decimal  @db.Decimal(12, 2)
  tgl_topup   DateTime
  id_user     Int?
  keterangan  String?  @db.VarChar(255)
  created_at  DateTime @default(now())

  // Kolom pembelian real via Digiflazz — null semua kalau ini catatan manual (jenis lama)
  metode            String   @default("Manual") @db.VarChar(20) // Manual | Digiflazz
  buyer_sku_code    String?  @db.VarChar(50)
  customer_no       String?  @db.VarChar(30)
  ref_id            String?  @unique @db.VarChar(50)
  status_transaksi  String?  @db.VarChar(20) // Pending | Sukses | Gagal
  harga_modal       Decimal? @db.Decimal(12, 2)
  serial_number     String?  @db.VarChar(100)
  provider_response String?  @db.Text

  sumber   SumberInternetSite? @relation(fields: [id_sumber], references: [id_sumber])
  aset_sim GudangAset?         @relation(fields: [id_aset_sim], references: [id_aset])
  site     SitePelanggan       @relation(fields: [id_site], references: [id_site])
  user     CoreUser?           @relation(fields: [id_user], references: [id_user])

  @@index([tgl_topup])
  @@map("sim_topup")
}

// Kredensial akun Digiflazz (PPOB) buat beli pulsa/paket data beneran —
// single-row config, sama pola dgn integration_prtg_config (API key
// terenkripsi, endpoint config terpisah dari AppSetting yg publik).
model IntegrationDigiflazzConfig {
  id          Int      @id @default(1)
  username    String?  @db.VarChar(100)
  api_key_enc String?  @db.Text
  mode        String   @default("production") @db.VarChar(20) // production | development (testing:true di Digiflazz)
  updated_at  DateTime @default(now()) @updatedAt

  @@map("integration_digiflazz_config")
}

// ============================================================

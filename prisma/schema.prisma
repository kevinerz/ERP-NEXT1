  id_ticket        Int       @unique
  id_user_pembuat  Int?
  penyebab_utama   String?   @db.Text
  dampak           String?   @db.Text
  solusi_sementara String?   @db.Text
  solusi_permanen  String?   @db.Text
  tgl_rca          DateTime? @db.Date
  created_at       DateTime  @default(now())

  ticket OperationTicket @relation(fields: [id_ticket], references: [id_ticket], onDelete: Cascade)

// ERP NEXT1 — Prisma Schema
// Generated dari erp_NEXT1_FINAL_v4.sql (36 tabel)
// Database: MariaDB 11.8

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// LAYER 1 — MASTER REFERENCE
// ============================================================

model CoreRole {
  id_role    Int      @id @default(autoincrement())
  nama_role  String   @unique @db.VarChar(100)
  deskripsi  String?  @db.VarChar(255)
  created_at DateTime @default(now())

  user_roles CoreUserRole[]

  @@map("core_roles")
}

model HrisKaryawan {
  id_karyawan   Int       @id @default(autoincrement())
  nip           String    @unique @db.VarChar(20)
  nama_lengkap  String    @db.VarChar(150)
  jabatan       String    @db.VarChar(100)
  departemen    String    @db.VarChar(50)
  no_hp         String?   @db.VarChar(20)
  email         String?   @db.VarChar(150)
  tgl_bergabung DateTime? @db.Date
  status_aktif  Boolean   @default(true)
  created_at    DateTime  @default(now())

  user             CoreUser?
  leads_pic        SalesLead[]         @relation("SalesPic")
  opportunities    SalesOpportunity[]  @relation("OppSalesPic")
  activities       SalesActivity[]     @relation("ActivitySalesPic")
  surveys          PresalesSurvey[]    @relation("SurveyPic")
  quotations       SalesQuotation[]    @relation("QuoSalesPic")
  quotations_approved SalesQuotation[] @relation("QuoApprover")
  projects_pm      ProjectDelivery[]
  tickets_teknisi  OperationTicket[]
  wo_teknisi       WorkOrder[]         @relation("WoTeknisiInternal")

  @@map("hris_karyawan")
}

model Pelanggan {
  id_pelanggan    Int      @id @default(autoincrement())
  kode_pelanggan  String   @unique @db.VarChar(20)
  nama_pelanggan  String   @db.VarChar(200)
  npwp            String?  @db.VarChar(30)
  alamat_kantor   String?  @db.Text
  email_billing   String?  @db.VarChar(150)
  no_telp         String?  @db.VarChar(20)
  nama_pic_utama  String?  @db.VarChar(100)
  no_hp_pic_utama String?  @db.VarChar(20)
  has_grup        Boolean  @default(false)
  nama_grup       String?  @db.VarChar(150)
  created_at      DateTime @default(now())

  sites SitePelanggan[]

  @@map("pelanggan")
}

model MasterLayanan {
  id_layanan   Int      @id @default(autoincrement())
  kode_layanan String   @unique @db.VarChar(20)
  nama_layanan String   @db.VarChar(100)
  deskripsi    String?  @db.Text
  is_managed   Boolean  @default(true)
  is_aktif     Boolean  @default(true)

  sites        SitePelanggan[]
  opportunities SalesOpportunity[]
  kontrak      KontrakLayanan[]

  @@map("master_layanan")
}

model MasterVendorIsp {
  id_vendor   Int      @id @default(autoincrement())
  nama_vendor String   @unique @db.VarChar(150)
  tipe_vendor String   @db.VarChar(30)
  kontak_pic  String?  @db.VarChar(100)
  email_pic   String?  @db.VarChar(150)
  no_telp     String?  @db.VarChar(20)
  catatan     String?  @db.Text
  is_aktif    Boolean  @default(true)
  created_at  DateTime @default(now())

  sumber_internet SumberInternetSite[]
  surveys_isp     PresalesSurvey[]
  work_orders_vendor WorkOrder[]       @relation("WoVendorKetiga")
  jurnal_ap       IntegrationJurnalAp[]

  @@map("master_vendor_isp")
}

// ============================================================
// LAYER 2 — USER & ACCESS
// ============================================================

model CoreUser {
  id_user       Int       @id @default(autoincrement())
  id_karyawan   Int       @unique
  username      String    @unique @db.VarChar(80)
  password_hash String    @db.VarChar(255)
  is_aktif      Boolean   @default(true)
  modul_akses   String?   @db.Text
  last_login    DateTime?
  created_at    DateTime  @default(now())

  karyawan     HrisKaryawan     @relation(fields: [id_karyawan], references: [id_karyawan])
  user_roles   CoreUserRole[]
  mutasi       GudangMutasiAset[]
  topup        SimTopup[]
  ticket_logs  OperationTicketLog[]
  rca          OperationRca[]

  @@map("core_users")
}

model CoreUserRole {
  id         Int      @id @default(autoincrement())
  id_user    Int
  id_role    Int
  created_at DateTime @default(now())

  user CoreUser @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  role CoreRole @relation(fields: [id_role], references: [id_role], onDelete: Cascade)

  @@unique([id_user, id_role])
  @@map("core_user_roles")
}


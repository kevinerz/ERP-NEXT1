model IntegrationPrtgWebhook {
  id_webhook          Int      @id @default(autoincrement())
  prtg_sensor_id      String?  @db.VarChar(50)
  prtg_device_name    String?  @db.VarChar(150)
  prtg_sensor_name    String?  @db.VarChar(150)
  status_sensor       String?  @db.VarChar(50)
  pesan_alert         String?  @db.Text
  id_ticket_terbentuk Int?
  diterima_pada       DateTime @default(now())

  ticket OperationTicket? @relation(fields: [id_ticket_terbentuk], references: [id_ticket])

  @@map("integration_prtg_webhooks")
}

// Konfigurasi koneksi PRTG dari UI (bukan lewat AppSetting — itu ada
// endpoint publik untuk branding login, kredensial PRTG tidak boleh ikut bocor
// di sana). Single-row, selalu id=1. Fallback ke env var kalau row belum ada.
model IntegrationPrtgConfig {
  id         Int      @id @default(1)
  base_url   String?  @db.VarChar(255)
  username   String?  @db.VarChar(100)
  passhash   String?  @db.VarChar(100)
  updated_at DateTime @default(now()) @updatedAt

  @@map("integration_prtg_config")
}

// Mapping manual nama device PRTG -> site pelanggan, dipakai saat matching
// otomatis (substring nama) gagal ("site tidak dikenali"). Sekali di-mapping,
// device itu langsung match persis di polling berikutnya.
model IntegrationPrtgMapping {
  id_mapping  Int      @id @default(autoincrement())
  device_name String   @unique @db.VarChar(150)
  id_site     Int
  created_at  DateTime @default(now())

  site SitePelanggan @relation(fields: [id_site], references: [id_site], onDelete: Cascade)

  @@map("integration_prtg_mapping")
}

model IntegrationRcmsWebhook {
  id_webhook          Int      @id @default(autoincrement())
  rcms_device_id      String?  @db.VarChar(100)
  imei_device         String?  @db.VarChar(20)
  status_device       String?  @db.VarChar(20)
  network_type        String?  @db.VarChar(10)
  signal_strength     String?  @db.VarChar(20)
  sim1_status         String?  @db.VarChar(50)
  sim2_status         String?  @db.VarChar(50)
  pesan_raw           String?  @db.Text
  id_ticket_terbentuk Int?
  diterima_pada       DateTime @default(now())

  ticket OperationTicket? @relation(fields: [id_ticket_terbentuk], references: [id_ticket])

  @@map("integration_rcms_webhooks")
}

model IntegrationRuijieWebhook {
  id_webhook          Int      @id @default(autoincrement())
  ruijie_device_id    String?  @db.VarChar(100)
  device_mac          String?  @db.VarChar(20)
  device_type         String?  @db.VarChar(20)
  status_device       String?  @db.VarChar(20)
  jenis_alert         String?  @db.VarChar(100)
  pesan_raw           String?  @db.Text
  id_ticket_terbentuk Int?
  diterima_pada       DateTime @default(now())

  ticket OperationTicket? @relation(fields: [id_ticket_terbentuk], references: [id_ticket])

  @@map("integration_ruijie_webhooks")
}

// ============================================================
// LAYER 9 — ACTIVITY LOG
// ============================================================

model ActivityLog {
  id_log     Int      @id @default(autoincrement())
  id_user    Int?
  username   String   @db.VarChar(80)
  nama       String?  @db.VarChar(150)
  aksi       String   @db.VarChar(20) // LOGIN, LOGOUT, CREATE, UPDATE, DELETE
  modul      String?  @db.VarChar(30)
  entitas    String?  @db.VarChar(60)
  deskripsi  String?  @db.Text
  ip_address String?  @db.VarChar(45)
  created_at DateTime @default(now())

  @@index([id_user])
  @@index([created_at])
  @@map("activity_log")
}

model Notification {
  id_notif   Int      @id @default(autoincrement())
  id_user    Int
  tipe       String   @db.VarChar(50) // quotation_approval, tiket_baru, tiket_update
  judul      String   @db.VarChar(200)
  deskripsi  String?  @db.Text
  url        String?  @db.VarChar(255)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([id_user, is_read])
  @@index([created_at])
  @@map("notifications")
}

// ============================================================
// LAYER 10 — APP SETTINGS
// ============================================================

model AppSetting {
  key        String   @id @db.VarChar(80)
  value      String?  @db.LongText
  updated_at DateTime @default(now()) @updatedAt

  @@map("app_settings")
}

// ============================================================
// LAYER 11 — FINANCE / INVOICE
// ============================================================

model Invoice {
  id_invoice      Int      @id @default(autoincrement())
  nomor_invoice   String   @unique @db.VarChar(50)
  id_kontrak      Int?
  id_site         Int
  periode         String   @db.VarChar(7) // "2026-07"
  tgl_invoice     DateTime @db.Date
  tgl_jatuh_tempo DateTime @db.Date
  subtotal        Decimal  @db.Decimal(15, 2)
  ppn_persen      Decimal  @default(11) @db.Decimal(5, 2)
  ppn_nominal     Decimal  @default(0) @db.Decimal(15, 2)
  total           Decimal  @db.Decimal(15, 2)
  jumlah_dibayar  Decimal  @default(0) @db.Decimal(15, 2)
  status          String   @default("Draft") @db.VarChar(20) // Draft, Terkirim, Sebagian, Lunas, Jatuh_Tempo, Batal
  catatan         String?  @db.Text
  mekari_uid      String?  @db.VarChar(100)
  mekari_status   String   @default("Belum") @db.VarChar(30) // Belum, Tersinkron, Simulasi, Gagal
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  kontrak    KontrakLayanan?     @relation(fields: [id_kontrak], references: [id_kontrak])
  site       SitePelanggan       @relation(fields: [id_site], references: [id_site])
  pembayaran InvoicePembayaran[]

  @@unique([id_kontrak, periode])
  @@index([status])
  @@index([periode])
  @@index([tgl_jatuh_tempo])
  @@map("invoices")
}

model InvoicePembayaran {
  id_pembayaran Int      @id @default(autoincrement())
  id_invoice    Int
  tgl_bayar     DateTime @db.Date
  jumlah        Decimal  @db.Decimal(15, 2)
  metode        String   @db.VarChar(30) // Transfer, Tunai, Virtual Account, Cek, Lainnya
  referensi     String?  @db.VarChar(100)
  catatan       String?  @db.Text
  id_user       Int?
  created_at    DateTime @default(now())

  invoice Invoice   @relation(fields: [id_invoice], references: [id_invoice], onDelete: Cascade)
  user    CoreUser? @relation(fields: [id_user], references: [id_user])

  @@index([id_invoice])
  @@map("invoice_pembayaran")
}

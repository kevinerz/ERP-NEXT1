  status_dari String?  @db.VarChar(50)
  status_ke   String?  @db.VarChar(50)
  catatan     String?  @db.Text
  created_at  DateTime @default(now())

  ticket OperationTicket @relation(fields: [id_ticket], references: [id_ticket], onDelete: Cascade)
  user   CoreUser?       @relation(fields: [id_user], references: [id_user])

  @@map("operation_ticket_logs")
}

model OperationRca {

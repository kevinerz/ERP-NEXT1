# ── ERP-NEXT1 — contoh environment variable ──────────────────────────
# Salin ke `.env` (jangan commit .env) lalu isi nilai aslinya.

# Database (MariaDB/MySQL)
DATABASE_URL="mysql://user:password@host:3306/nama_database"

# JWT
JWT_SECRET="ganti-dengan-secret-acak-panjang"
JWT_REFRESH_SECRET="ganti-dengan-secret-acak-lain"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
# Daftar origin yang diizinkan CORS, pisah dengan koma
CORS_ORIGIN="http://localhost:5173"

# ── Mailer sistem (noreply) — dipakai MailerService lintas modul ──────
# Akun email infra tetap untuk email otomatis (onboarding, notifikasi, broadcast).
MAIL_HOST="smtp.hostinger.com"
MAIL_PORT=465
MAIL_USER="noreply@nextone.id"
MAIL_PASSWORD="password-mailbox-noreply"
# Nama tampilan pengirim (opsional) → From: "Next1 ERP" <noreply@nextone.id>
MAIL_FROM_NAME="Next1 ERP"

# ── Integrasi (opsional) ──────────────────────────────────────────────
PRTG_BASE_URL=""
PRTG_USERNAME=""
PRTG_PASSHASH=""
MEKARI_CLIENT_ID=""
MEKARI_CLIENT_SECRET=""
MEKARI_BASE_URL="https://api.mekari.com"

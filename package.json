{
  "name": "erp-next1",
  "version": "1.0.0",
  "description": "ERP PT. Perdana Global Internet (NEXT1)",
  "author": "NEXT1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build:web": "cd web && npm install --legacy-peer-deps --include=dev && npm run build",
    "build:api": "npx prisma generate && npx @nestjs/cli build",
    "build": "npm run build:web && npm run build:api",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "seed": "npx ts-node -r tsconfig-paths/register prisma/seed.ts",
    "version:bump": "node scripts/bump-version.js"
  },
  "prisma": {
    "seed": "npx ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mapped-types": "^2.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.0.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cloudinary": "^2.0.0",
    "handlebars": "^4.7.8",
    "multer": "^2.0.0",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/multer": "^1.4.7",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^3.0.0"
  }
}

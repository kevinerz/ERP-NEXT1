{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:dev"],
      "port": 3000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "web",
      "port": 5173
    },
    {
      "name": "soperp",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "../soperp", "-l", "8082"],
      "port": 8082
    }
  ]
}
